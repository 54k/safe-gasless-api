RPC_URL=http://localhost:8545

# Relayer wallet. Must hold ETH to pay gas for user deployments and meta-transactions.
BACKEND_PRIVATE_KEY=

# Gnosis Safe factory/proxy addresses. Values below are mainnet defaults; override per network.
MASTER_COPY_CONTRACT_ADDRESS=
FALLBACK_ADDRESS=

# Deterministic salt for CREATE2. Any 32-byte hex value.
SALT_NONCE=0xcafebabe
